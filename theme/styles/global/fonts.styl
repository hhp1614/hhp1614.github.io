@font-face
  font-family 'Source Code Variable'
  font-style normal
  src local('Source Code Variable'),
    url('/fonts/SourceCodeVariable-Roman.ttf') format('truetype')

@font-face
  font-family 'Source Code Variable Italic'
  font-style italic
  src local('Source Code Variable Italic'),
    url('/fonts/SourceCodeVariable-Italic.ttf') format('truetype')
