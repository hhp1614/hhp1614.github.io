.index
  display flex
  flex-direction column

  .list
    flex 1
    height 100%
    overflow hidden

    .item
      overflow hidden

      .title
        font-size 20px
        color #00bdd6

      .date
        font-size 12px
        color $obviousColor

  .pagination
    position relative
    line-height $lineHeight
    text-align center
    font-size 12px
    color $obviousColor

    .prev
      position absolute
      top 0
      left 0

    .next
      position absolute
      top 0
      right 0

    .prev, .next
      color #ff5792

      &::after
        background-color @color