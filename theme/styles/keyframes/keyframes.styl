@keyframes page-in
  from
    opacity 0
    transform translateY(2vmin)

  to
    opacity 1
    transform translateY(0)

@keyframes page-out
  from
    opacity 1
    transform translateY(0)

  to
    opacity 0
    transform translateY(2vmin)

@keyframes head-in
  from
    transform translateY(-100%)

  to
    transform translateY(0)

@keyframes head-out
  from
    transform translateY(0)

  to
    transform translateY(-100%)

@keyframes foot-in
  from
    transform translateY(100%)

  to
    transform translateY(0)

@keyframes foot-out
  from
    transform translateY(0)

  to
    transform translateY(100%)